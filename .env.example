# --- Base de datos (Supabase / PostgreSQL) — obligatorio en Netlify y recomendado en local ---
# En Supabase: Settings → Database → Connection string (Transaction pooler = DATABASE_URL, Session = DIRECT_URL)
# Local / si el pooler no conecta: usá host db.PROJECT_REF.supabase.co:5432 (usuario postgres)
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
# Netlify (opcional pooler): ...pooler.supabase.com:6543?pgbouncer=true y DIRECT_URL en :5432 pooler o db.

# URL pública del sitio (en Netlify: https://tu-sitio.netlify.app)
NEXT_PUBLIC_APP_URL=

# Contraseña del panel (/login). Vacío = panel abierto en local.
PANEL_PASSWORD=

# Formulario público /cargar — si está vacío, no pide ?k=
PUBLIC_CARGA_KEY=

# Una sola vez tras deploy: POST /api/admin/seed con header x-seed-secret
SEED_SECRET=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_TEMPLATE=hello_world
WHATSAPP_DEFAULT_TEMPLATE_LANG=en_US
