# --- Base de datos Neon (PostgreSQL) ---
# En Neon: Connect → pestaña .env → DATABASE_URL (pooled) y DATABASE_URL_UNPOOLED (= DIRECT_URL)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# URL pública del sitio en Netlify
NEXT_PUBLIC_APP_URL=https://tu-sitio.netlify.app

# Contraseña del panel (/login). Vacío = panel abierto en local.
PANEL_PASSWORD=

# Formulario público /cargar — si está vacío, no pide ?k=
PUBLIC_CARGA_KEY=

# Orígenes del portal municipal (CORS), separados por coma. Ej: https://tu-portal.netlify.app
PORTAL_MUNICIPAL_ORIGINS=

# Una sola vez tras deploy: POST /api/admin/seed con header x-seed-secret
SEED_SECRET=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_TEMPLATE=hello_world
WHATSAPP_DEFAULT_TEMPLATE_LANG=en_US

# Plantilla Meta para avisos de agenda interna del portal municipal (5 variables en el cuerpo).
WHATSAPP_AGENDA_TEMPLATE=agenda_evento_interno
WHATSAPP_AGENDA_TEMPLATE_LANG=es_AR
